# ============================================================
#  .env.example — DeFi MCP Tool Server
#  Copy to .env and fill in your keys. Never commit .env.
# ============================================================

# ── CoinGecko ───────────────────────────────────────────────
# Free key: https://www.coingecko.com/en/api
COINGECKO_API_KEY=YOUR_COINGECKO_KEY_HERE

# ── Arkham Intelligence (primary whale tracker) ─────────────
# Apply: https://docs.arkhamintelligence.com
ARKHAM_API_KEY=YOUR_ARKHAM_KEY_HERE

# ── Nansen (fallback whale tracker) ─────────────────────────
# Apply: https://www.nansen.ai/api
NANSEN_API_KEY=YOUR_NANSEN_KEY_HERE

# ── Ollama (local — no key needed) ──────────────────────────
# Run `ollama list` to see your installed models
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── MCP Server Transport ─────────────────────────────────────
# "stdio" for local agents | "streamable-http" for remote
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000

# ── Alert Thresholds ─────────────────────────────────────────
PRICE_ALERT_PCT=5.0
TVL_ALERT_PCT=10.0
WHALE_THRESHOLD_USD=100000

# ── Cache & Polling ───────────────────────────────────────────
CACHE_TTL_SECONDS=30
POLL_INTERVAL_SECONDS=60

# ── TokenSniffer (clone/pattern detection) ──────────────────────────────
# Apply: https://tokensniffer.com ($100-200/month — optional, falls back gracefully)
TOKENSNIFFER_API_KEY=YOUR_TOKENSNIFFER_KEY_HERE

# ── Alchemy WebSocket (copy trade wallet watching) ───────────────────────
# Get at: https://alchemy.com (free tier works)
ALCHEMY_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Ollama embedding model (optional — for semantic search features) ────
OLLAMA_EMBED_MODEL=nomic-embed-text
